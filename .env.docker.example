# ── CustomerPanel AI — Docker Dev Environment ────────────────────────────────
# Copy to .env.docker and fill in secrets ( .env.docker is gitignored )
# Used by: docker compose --env-file .env.docker -f docker-compose.dev.yml up

ENGINE_SECRET=dev-secret
SHOPIFY_APP_CALLBACK_URL=https://dev.auctovio.com

# Get keys from console — never commit real values
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
ZEP_API_KEY=
