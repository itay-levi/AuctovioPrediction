generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id              String            @id @default(cuid())
  shopDomain      String            @unique
  accessToken     String
  planTier        PlanTier          @default(FREE)
  mtBudgetUsed    Int               @default(0)
  shopType        String?
  healthScore     Int?
  lastWeeklyScan  DateTime?
  installedAt     DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  competitors     CompetitorWatch[]
  simulations     Simulation[]
}

model Simulation {
  id                   String           @id @default(cuid())
  storeId              String
  productUrl           String
  productJson          Json?
  status               SimulationStatus @default(PENDING)
  phase                Int              @default(0)
  mtCost               Int              @default(0)
  score                Int?
  imageScore           Int?
  reportJson           Json?
  originalSimulationId String?          // set on delta/what-if runs
  deltaParams          Json?            // {price?, shippingDays?} overrides
  synthesisText        String?          // Compressed Intelligence Report text
  synthesisGeneratedAt DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  agentLogs            AgentLog[]
  store                Store            @relation(fields: [storeId], references: [id])
  original             Simulation?      @relation("DeltaRuns", fields: [originalSimulationId], references: [id])
  deltas               Simulation[]     @relation("DeltaRuns")
}

model AgentLog {
  id             String     @id @default(cuid())
  simulationId   String
  agentId        String
  archetype      String     // archetype id (snake_case)
  archetypeName  String?    // display name from dynamic generation e.g. "The Weekend Warrior"
  archetypeEmoji String?    // emoji from dynamic generation e.g. "🏂"
  phase          Int
  verdict        String
  reasoning      String
  createdAt      DateTime   @default(now())
  simulation     Simulation @relation(fields: [simulationId], references: [id])

  @@index([simulationId])
}

model CompetitorWatch {
  id          String    @id @default(cuid())
  storeId     String
  productUrl  String
  lastScanned DateTime?
  lastScore   Int?
  createdAt   DateTime  @default(now())
  store       Store     @relation(fields: [storeId], references: [id])
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum SimulationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
