generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id           String            @id @default(cuid())
  shopDomain   String            @unique
  accessToken  String
  planTier     PlanTier          @default(FREE)
  mtBudgetUsed Int               @default(0)
  shopType     String?
  installedAt  DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  competitors  CompetitorWatch[]
  simulations  Simulation[]
}

model Simulation {
  id          String           @id @default(cuid())
  storeId     String
  productUrl  String
  productJson Json?
  status      SimulationStatus @default(PENDING)
  phase       Int              @default(0)
  mtCost      Int              @default(0)
  score       Int?
  imageScore  Int?
  reportJson  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  agentLogs   AgentLog[]
  store       Store            @relation(fields: [storeId], references: [id])
}

model AgentLog {
  id           String     @id @default(cuid())
  simulationId String
  agentId      String
  archetype    String
  phase        Int
  verdict      String
  reasoning    String
  createdAt    DateTime   @default(now())
  simulation   Simulation @relation(fields: [simulationId], references: [id])

  @@index([simulationId])
}

model CompetitorWatch {
  id          String    @id @default(cuid())
  storeId     String
  productUrl  String
  lastScanned DateTime?
  lastScore   Int?
  createdAt   DateTime  @default(now())
  store       Store     @relation(fields: [storeId], references: [id])
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum SimulationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
