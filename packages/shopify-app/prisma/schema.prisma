generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled — used by Prisma queries at runtime
  directUrl = env("DIRECT_DATABASE_URL") // direct — used by prisma db push / migrate
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id              String            @id @default(cuid())
  shopDomain      String            @unique
  accessToken     String
  planTier        PlanTier          @default(FREE)
  mtBudgetUsed    Int               @default(0)
  shopType        String?
  healthScore     Int?
  lastWeeklyScan  DateTime?
  installedAt     DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  competitors     CompetitorWatch[]
  simulations     Simulation[]
}

enum SimulationType {
  WHATIF
  RETAKE
}

model Simulation {
  id                   String           @id @default(cuid())
  storeId              String
  productUrl           String
  productJson          Json?
  status               SimulationStatus @default(PENDING)
  phase                Int              @default(0)
  mtCost               Int              @default(0)
  score                Int?
  imageScore           Int?
  reportJson           Json?
  originalSimulationId String?          // set on delta/what-if/retake runs
  deltaParams          Json?            // {price?, shippingDays?} overrides
  simulationType       SimulationType?  // null = original scan, WHATIF = lab delta, RETAKE = retake test
  retakeEvaluation     Json?            // {verdicts:[{lens,verdict,delta,polishingTouch}], overallVerdict, overallPolishingTouch}
  synthesisText        String?          // Compressed Intelligence Report text
  synthesisGeneratedAt DateTime?
  focusAreas           Json?            // ["trust_credibility", "price_value"]
  recommendations      Json?            // [{priority, title, impact, the_why}]
  trustAudit           Json?            // trust audit result from engine
  comparisonInsight    String?          // AI explanation of what-if score delta
  labGroupId           String?          // links baseline + target Lab sims together
  isBaseline           Boolean          @default(false) // true = general-public baseline run
  comparisonSummary    Json?            // {scoreDelta, whyGap, divergenceTopics, targetPersonaCard}
  productDna           Json?            // {coreFear, coreDesire, personaHooks} — cached from Phase 0
  failureReason        String?          // merchant-friendly error message when status = FAILED
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  agentLogs            AgentLog[]
  store                Store            @relation(fields: [storeId], references: [id])
  original             Simulation?      @relation("DeltaRuns", fields: [originalSimulationId], references: [id])
  deltas               Simulation[]     @relation("DeltaRuns")
}

model AgentLog {
  id                String     @id @default(cuid())
  simulationId      String
  agentId           String
  archetype         String     // archetype id (snake_case)
  archetypeName     String?    // display name e.g. "Budget Optimizer"
  archetypeEmoji    String?    // emoji e.g. "💰"
  personaName       String?    // human name e.g. "Marcus"
  personaAge        Int?       // e.g. 34
  personaOccupation String?    // e.g. "Professional Athlete"
  personaMotivation String?    // e.g. "Values Durability"
  nicheConcern      String?    // "Why I'm here" — product-specific concern
  phase             Int
  verdict           String
  confidenceScore   Int?       // 0-100 continuous score (null for legacy rows)
  reasoning         String
  createdAt         DateTime   @default(now())
  simulation        Simulation @relation(fields: [simulationId], references: [id])

  @@index([simulationId])
}

model CompetitorWatch {
  id          String    @id @default(cuid())
  storeId     String
  productUrl  String
  lastScanned DateTime?
  lastScore   Int?
  createdAt   DateTime  @default(now())
  store       Store     @relation(fields: [storeId], references: [id])
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum SimulationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
