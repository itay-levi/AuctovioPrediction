# ── Fast LLM — Groq 8B (pre-processing: DNA, intelligence, archetypes, gaps) ─
# Free tier: 30 RPM / 6,000 TPM. Set LLM_RPM=0 on paid tier.
LLM_API_KEY=your_groq_api_key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.1-8b-instant
LLM_RPM=5

# ── Deep LLM — Groq 70B (debate phases P1/P2/P3 + recommendations) ──────────
# Separate rate-limit quota from 8B. Set DEEP_LLM_RPM=0 on paid tier.
DEEP_LLM_MODEL_NAME=llama-3.3-70b-versatile
DEEP_LLM_RPM=5
DEEP_LLM_TPM_LIMIT=5500

# ── Fallback LLM — Gemini (fires when Groq 429s on either model) ─────────────
FALLBACK_LLM_API_KEY=your_gemini_api_key
FALLBACK_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
FALLBACK_LLM_MODEL_NAME=gemini-1.5-flash

# ── Zep Cloud (agent memory) ─────────────────────────────────────────────────
# Free tier available at https://app.getzep.com
ZEP_API_KEY=

# ── MiroShop auth (must match ENGINE_API_KEY in Shopify app .env) ────────────
ENGINE_API_KEY=dev-secret-change-in-prod
SHOPIFY_APP_API_KEY=dev-secret-change-in-prod

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to 1 only on tiny local models (< 8B) that can't handle structured JSON prompts.
# On Groq with llama-3.1-8b-instant this must be 0 — disabling it kills all fast-model calls.
SKIP_ARCHETYPE_GEN=0

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=true
SECRET_KEY=dev-flask-secret-change-in-prod
