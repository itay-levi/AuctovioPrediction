# ── Root .env for docker-compose.dev.yml ─────────────────────────────────────
# Copy this to .env and fill in your real values.
# This file is gitignored — never commit .env

# Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google AI (Gemini) API key (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Shared secret between Shopify app and engine (any random string, e.g. openssl rand -hex 32)
# Must match ENGINE_API_KEY in packages/shopify-app/.env
ENGINE_SECRET=dev-secret-change-in-prod

# Zep Cloud API key (optional — agent memory, https://app.getzep.com)
ZEP_API_KEY=
